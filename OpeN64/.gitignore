# For PCBs designed using KiCad: http://www.kicad-pcb.org/
# Format documentation: http://kicad-pcb.org/help/file-formats/

# Temporary files
*.000
*.kicad_prl
*~
_autosave-*
*.tmp
*-save.pro
*-save.kicad_pcb
fp-info-cache

# Netlist files (exported from Eeschema)
*.net

# Autorouter files (exported from Pcbnew)
*.dsn
*.ses

# Exported BOM files
*.xml
*.csv

# Backup files
*-backups/
*.bak
*.bck
*.kicad_pcb-bak
*.kicad_sch-bak
*.sch-bak

# End of https://mrkandreev.name/snippets/gitignore-generator/#KiCad